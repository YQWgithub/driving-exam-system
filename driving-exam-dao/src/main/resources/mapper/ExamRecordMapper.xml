<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drivingexam.dao.ExamRecordMapper">
    <resultMap id="BaseResultMap" type="com.drivingexam.entity.ExamRecord">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="paper_id" property="paperId"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="score" property="score"/>
        <result column="total" property="total"/>
        <result column="is_pass" property="isPass"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, paper_id, start_time, end_time, score, total, is_pass, status, create_time
    </sql>

    <insert id="insert" parameterType="com.drivingexam.entity.ExamRecord" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO exam_record (user_id, paper_id, start_time, score, total, is_pass, status, create_time)
        VALUES (#{userId}, #{paperId}, #{startTime}, #{score}, COALESCE(#{total}, 100), #{isPass}, #{status}, #{createTime})
    </insert>

    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM exam_record WHERE id = #{id}
    </delete>

    <update id="update" parameterType="com.drivingexam.entity.ExamRecord">
        UPDATE exam_record
        <set>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="score != null">score = #{score},</if>
            <if test="total != null">total = #{total},</if>
            <if test="isPass != null">is_pass = #{isPass},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE exam_record SET status = #{status} WHERE id = #{id}
    </update>

    <update id="updateScore">
        UPDATE exam_record SET score = #{score}, total = #{total}, is_pass = #{isPass} WHERE id = #{id}
    </update>

    <select id="selectById" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM exam_record WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM exam_record ORDER BY create_time DESC
    </select>

    <select id="selectByUserId" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM exam_record WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="selectByUserIdAndStatus" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM exam_record WHERE user_id = #{userId} AND status = #{status} ORDER BY create_time DESC
    </select>
</mapper>
