<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drivingexam.dao.AnswerDetailMapper">
    <resultMap id="BaseResultMap" type="com.drivingexam.entity.AnswerDetail">
        <id column="id" property="id"/>
        <result column="exam_record_id" property="examRecordId"/>
        <result column="question_id" property="questionId"/>
        <result column="user_answer" property="userAnswer"/>
        <result column="is_correct" property="isCorrect"/>
        <result column="answer_time" property="answerTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, exam_record_id, question_id, user_answer, is_correct, answer_time
    </sql>

    <insert id="insert" parameterType="com.drivingexam.entity.AnswerDetail" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO answer_detail (exam_record_id, question_id, user_answer, is_correct, answer_time)
        VALUES (#{examRecordId}, #{questionId}, #{userAnswer}, #{isCorrect}, #{answerTime})
    </insert>

    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM answer_detail WHERE id = #{id}
    </delete>

    <update id="update" parameterType="com.drivingexam.entity.AnswerDetail">
        UPDATE answer_detail
        <set>
            <if test="userAnswer != null">user_answer = #{userAnswer},</if>
            <if test="isCorrect != null">is_correct = #{isCorrect},</if>
            <if test="answerTime != null">answer_time = #{answerTime},</if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectById" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM answer_detail WHERE id = #{id}
    </select>

    <select id="selectByExamRecordId" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM answer_detail WHERE exam_record_id = #{examRecordId}
    </select>

    <select id="selectByExamRecordIdAndQuestionId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM answer_detail 
        WHERE exam_record_id = #{examRecordId} AND question_id = #{questionId}
    </select>
</mapper>
