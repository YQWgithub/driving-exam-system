<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.drivingexam.dao.ExamPaperMapper">
    <resultMap id="BaseResultMap" type="com.drivingexam.entity.ExamPaper">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="duration" property="duration"/>
        <result column="total_score" property="totalScore"/>
        <result column="pass_score" property="passScore"/>
        <result column="question_count" property="questionCount"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.drivingexam.entity.ExamPaper" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO exam_paper (title, duration, total_score, pass_score, question_count, create_time)
        VALUES (#{title}, #{duration}, #{totalScore}, #{passScore}, #{questionCount}, NOW())
    </insert>

    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM exam_paper WHERE id = #{id}
    </delete>

    <update id="update" parameterType="com.drivingexam.entity.ExamPaper">
        UPDATE exam_paper
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="totalScore != null">total_score = #{totalScore},</if>
            <if test="passScore != null">pass_score = #{passScore},</if>
            <if test="questionCount != null">question_count = #{questionCount},</if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectById" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT * FROM exam_paper WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM exam_paper ORDER BY create_time DESC
    </select>
</mapper>
